<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="500.0" prefWidth="750.0" spacing="10.0"
      stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chat.client.ChatController">    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <ListView fx:id="listaMensajes" VBox.vgrow="ALWAYS" />
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="inputMensaje" onAction="#enviarMensaje" promptText="Escribe un mensaje aquí..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="botonEnviar" mnemonicParsing="false" onAction="#enviarMensaje" text="Enviar" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox prefWidth="180.0" spacing="10.0">
            <children>
                <ListView fx:id="listaUsuarios" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

    </children>
</HBox>