<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.chat.client.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="JavaChat Sign In" styleClass="titulo">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label text="Usuario:" />
                <TextField fx:id="txtUsuario" promptText="Introduce tu usuario" />
            </children>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label text="Contraseña:" />
                <PasswordField fx:id="txtPassword" promptText="******" />
            </children>
        </VBox>
        <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" text="Iniciar Sesión">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <Button fx:id="btnRegistro" text="Crear Cuenta Nueva" onAction="#handleRegistro"
                style="-fx-background-color: transparent; -fx-text-fill: #7aa2f7; -fx-cursor: hand; -fx-font-size: 14px; -fx-underline: true;"/>
        <Label fx:id="lblError" styleClass="error-label" textFill="RED" />
    </children>
</VBox>